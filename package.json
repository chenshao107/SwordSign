{
  "name": "swordsign",
  "displayName": "SwordSign",
  "description": "通过文字水印快速区分 VSCode 窗口",
  "version": "0.0.4",
  "publisher": "chenshao",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "watermark",
    "background",
    "window",
    "标识",
    "水印",
    "sword"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "swordsign.refresh",
        "title": "刷新标识（随机切换名剑）",
        "category": "SwordSign"
      },
      {
        "command": "swordsign.toggle",
        "title": "切换总开关",
        "category": "SwordSign"
      },
      {
        "command": "swordsign.toggleWatermark",
        "title": "切换背景水印",
        "category": "SwordSign"
      },
      {
        "command": "swordsign.toggleStatusBar",
        "title": "切换状态栏显示",
        "category": "SwordSign"
      },
      {
        "command": "swordsign.toggleWindowTitle",
        "title": "切换窗口标题显示",
        "category": "SwordSign"
      },
      {
        "command": "swordsign.setText",
        "title": "设置自定义标识文字",
        "category": "SwordSign"
      }
    ],
    "configuration": {
      "title": "SwordSign",
      "properties": {
        "swordsign.enabled": {
          "type": "boolean",
          "default": true,
          "description": "总开关：是否启用 SwordSign"
        },
        "swordsign.showWatermark": {
          "type": "boolean",
          "default": false,
          "description": "是否显示背景水印（默认关闭，建议用状态栏和窗口标题）"
        },
        "swordsign.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "是否在状态栏显示标识（仅工作区有效）"
        },
        "swordsign.statusBarColor": {
          "type": "string",
          "default": "",
          "description": "状态栏文字颜色，如 #FF0000、red（仅工作区有效）"
        },
        "swordsign.statusBarBackground": {
          "type": "string",
          "default": "",
          "description": "状态栏背景颜色，如 #FF0000、red（仅工作区有效）"
        },
        "swordsign.showWindowTitle": {
          "type": "boolean",
          "default": true,
          "description": "是否在窗口标题显示标识"
        },
        "swordsign.text": {
          "type": "string",
          "default": "",
          "description": "自定义标识文字，为空则从名剑谱中随机选取"
        },
        "swordsign.opacity": {
          "type": "number",
          "default": 0.08,
          "minimum": 0,
          "maximum": 1,
          "description": "水印透明度 (0-1)"
        },
        "swordsign.fontSize": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 100,
          "description": "文字大小"
        },
        "swordsign.angle": {
          "type": "number",
          "default": -30,
          "minimum": -90,
          "maximum": 90,
          "description": "文字倾斜角度"
        },
        "swordsign.fontFamily": {
          "type": "string",
          "default": "Microsoft YaHei, SimHei, sans-serif",
          "description": "字体族"
        },
        "swordsign.spacingX": {
          "type": "number",
          "default": 200,
          "minimum": 50,
          "maximum": 500,
          "description": "水印水平间距"
        },
        "swordsign.spacingY": {
          "type": "number",
          "default": 150,
          "minimum": 50,
          "maximum": 500,
          "description": "水印垂直间距"
        },
        "swordsign.color": {
          "type": "string",
          "default": "#808080",
          "description": "水印文字颜色"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chenshao107/SwordSign.git"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.9.3"
  }
}
